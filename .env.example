# RabbitMQ connection
RABBITMQ_URL=amqp://tbx_user:tbx_pass@localhost:5672/tbx

# Simulator settings
SIMULATOR_ORDER_COUNT=10
SIMULATOR_INTERVAL_MS=3000
SIMULATOR_EXCEPTION_RATE=0.10
SIMULATOR_DATE_CHANGE_RATE=0.20
SIMULATOR_PARTIAL_RECEIVE_RATE=0.15

# MongoDB connection
MONGODB_URL=mongodb://localhost:27017/tbx

# API settings
API_PORT=3001

# Power Automate webhook (optional)
# Set this to your Power Automate HTTP trigger URL to push events in real time.
# Leave blank to disable webhook notifications.
POWER_AUTOMATE_WEBHOOK_URL=
